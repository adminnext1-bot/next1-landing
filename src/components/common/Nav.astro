---
const links = [
  { label: 'Về chúng tôi', key: 'nav.about',      href: '/#about' },
  { label: 'Dịch vụ',      key: 'nav.services',    href: '/#pillars' },
  { label: 'Thành viên',   key: 'nav.membership',  href: '/#membership' },
  { label: 'Đối tác',      key: 'nav.partners',    href: '/brokers' },
  { label: 'Blog',          key: 'nav.blog',        href: '/blog' },
  { label: 'Liên hệ',      key: 'nav.contact',     href: '/#contact' },
];

const APP_URL = 'https://app.next1hub.com';
---

<nav
  id="main-nav"
  class="fixed top-0 inset-x-0 z-50 flex items-center justify-between
         px-6 md:px-14 py-4 md:py-5
         border-b border-white/10 bg-ink/85 backdrop-blur-xl
         transition-shadow duration-300"
>
  <!-- Logo -->
  <a href="/" class="no-underline flex items-center">
    <img src="/logo.png" alt="NEXT 1" class="h-8 w-auto" />
  </a>

  <!-- Desktop nav links -->
  <ul class="hidden md:flex gap-10 list-none mr-auto ml-10">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          data-i18n={l.key}
          class="relative text-[13px] font-normal tracking-[0.12em] uppercase text-white/80
                 no-underline pb-1
                 after:absolute after:bottom-0 after:left-0 after:h-px after:w-0
                 after:bg-gold after:transition-[width] after:duration-300 hover:after:w-full
                 hover:text-gold transition-colors duration-200"
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Desktop CTAs -->
  <div class="hidden md:flex items-center gap-3">
    <!-- Language toggle -->
    <button
      data-lang-toggle
      class="w-10 h-[38px] border border-white/20 text-white/50 text-[11px] font-mono
             tracking-[0.15em] uppercase hover:border-gold hover:text-gold
             transition-all duration-300"
    >
      EN
    </button>

    <!-- Login -->
    <a
      href={`${APP_URL}/login`}
      data-i18n="nav.login"
      class="px-5 py-2.5
             border border-white/30 text-white/70 text-[12px] font-medium tracking-[0.12em] uppercase
             no-underline transition-all duration-300
             hover:border-white/60 hover:text-white"
    >
      Đăng nhập
    </a>

    <!-- Join CTA -->
    <a
      href="#membership"
      data-i18n="nav.join"
      class="px-7 py-2.5
             border border-gold text-gold text-[12px] font-medium tracking-[0.12em] uppercase
             no-underline transition-all duration-300
             hover:bg-gold hover:text-ink hover:shadow-[0_0_24px_rgba(201,168,76,0.25)]"
    >
      Tham gia ngay
    </a>
  </div>

  <!-- Hamburger -->
  <button
    id="menu-toggle"
    class="md:hidden flex flex-col gap-[5px] p-2 -mr-1"
    aria-label="Toggle menu"
    aria-expanded="false"
  >
    <span id="bar-top" class="block w-6 h-px bg-white/70 transition-all duration-300 origin-center"></span>
    <span id="bar-mid" class="block w-4 h-px bg-white/70 transition-all duration-300"></span>
    <span id="bar-bot" class="block w-6 h-px bg-white/70 transition-all duration-300 origin-center"></span>
  </button>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-ink/[0.97] backdrop-blur-2xl
         flex flex-col items-center justify-center gap-8 pt-16"
>
  {links.map((l) => (
    <a
      href={l.href}
      data-i18n={l.key}
      class="font-serif text-3xl text-white/80 hover:text-gold transition-colors no-underline tracking-wide"
    >
      {l.label}
    </a>
  ))}

  <!-- Mobile: Login -->
  <a
    href={`${APP_URL}/login`}
    data-i18n="nav.login"
    class="mt-2 px-10 py-3 border border-white/30 text-white/70 text-sm font-medium
           tracking-[0.15em] uppercase no-underline hover:border-white hover:text-white transition-all"
  >
    Đăng nhập
  </a>

  <!-- Mobile: Join -->
  <a
    href="#membership"
    data-i18n="nav.join"
    class="px-10 py-4 border border-gold text-gold text-sm font-medium
           tracking-[0.15em] uppercase no-underline hover:bg-gold hover:text-ink transition-all"
  >
    Tham gia ngay
  </a>

  <!-- Mobile: Language toggle -->
  <button
    data-lang-toggle
    class="px-8 py-2.5 border border-white/15 text-white/40 text-[11px] font-mono
           tracking-[0.2em] uppercase hover:border-gold/40 hover:text-gold transition-all"
  >
    EN
  </button>
</div>
