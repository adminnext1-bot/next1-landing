---
const plans = [
  {
    name: 'Cộng đồng chuyên nghiệp',
    subtitle: 'Nền tảng kiến thức & phân tích thị trường',
    price: '0',
    currency: '',
    suffix: 'đ',
    period: 'Miễn phí mãi mãi',
    features: [
      'Kiến thức tài chính từ cơ bản đến nâng cao theo lộ trình chuẩn',
      'Kiến thức giao dịch đa thị trường: Forex, Crypto, Hàng hóa, Cổ phiếu',
      'Phân tích thị trường chuyên sâu hàng tuần, định hướng rõ, không cảm tính',
      'Tham gia cộng đồng trao đổi & hỗ trợ lẫn nhau 24/7',
      'Webinar & workshop định kỳ mở cho toàn bộ thành viên',
    ],
    cta: 'Tham gia miễn phí',
    featured: false,
    badge: null,
  },
  {
    name: 'Cashback',
    subtitle: 'Tối ưu chi phí giao dịch — nhận hoàn tiền trên từng lệnh',
    price: 'Hoàn phí',
    currency: '',
    suffix: '',
    period: 'giao dịch',
    features: [
      'Hoàn tiền trên mỗi lot giao dịch thực tế',
      'Áp dụng với các sàn môi giới quốc tế uy tín trong hệ sinh thái NEXT 1',
      'Không yêu cầu thay đổi chiến lược hay điều kiện giao dịch hiện tại',
      'Thanh toán hoàn tiền minh bạch, đúng hạn theo chu kỳ cam kết',
      'Hỗ trợ mở tài khoản & tư vấn tối ưu điều kiện giao dịch tốt nhất',
    ],
    cta: 'Xem sàn đối tác',
    ctaHref: '/brokers',
    featured: true,
    badge: 'PHỔ BIẾN NHẤT',
  },
  {
    name: 'Investing Advice',
    subtitle: 'Quản lý vốn toàn diện, cá nhân hóa theo mục tiêu tài chính',
    price: '1-on-1',
    currency: '',
    suffix: '',
    period: 'Tư vấn cá nhân hóa',
    features: [
      'Tư vấn chiến lược đầu tư cá nhân hóa theo khẩu vị rủi ro & mục tiêu',
      'Copytrading & PAMM/MAMM',
      'Chăm sóc tài khoản 1-on-1: quản lý rủi ro, review định kỳ, điều chỉnh chiến lược',
      'Kết nối trực tiếp với quỹ đầu tư & nhà đầu tư tổ chức',
      'Ưu tiên tiếp cận sản phẩm đầu tư mới & cơ hội độc quyền',
    ],
    cta: 'Liên hệ tư vấn',
    featured: false,
    badge: null,
  },
];
---

<section id="membership" class="relative z-10 bg-ink-2 border-b border-white/10 px-6 md:px-16 py-16 md:py-28">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-12 md:mb-20 reveal">
      <span class="section-label text-center mb-4">// 03 — Membership</span>
      <h2 class="section-title">
        Chọn hành trình<br /><span class="text-gold italic font-normal">của bạn</span>
      </h2>
      <p class="mt-5 text-[15px] text-white/40 max-w-[400px] mx-auto leading-relaxed">
        Từ nền tảng kiến thức đến tư vấn cá nhân — mỗi cấp độ là một bước tiến trong hành trình tài chính của bạn.
      </p>
    </div>

    <!-- Plans -->
    <div class="grid md:grid-cols-3 gap-6">
      {plans.map((plan, i) => (
        <div
          class={[
            'relative flex flex-col p-6 md:p-8 transition-all duration-300 reveal',
            plan.featured
              ? 'border border-gold bg-gradient-to-b from-gold/[0.07] to-transparent'
              : 'border border-white/10 bg-ink hover:border-white/25',
          ].join(' ')}
          style={`animation-delay: ${i * 0.1}s`}
        >
          {plan.badge && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2
                         bg-gold text-ink text-[9px] font-bold tracking-[0.22em] uppercase px-4 py-1">
              {plan.badge}
            </span>
          )}

          <div class="font-mono text-[11px] tracking-[0.3em] uppercase text-gold mb-2">{plan.name}</div>
          <p class="text-[12px] text-white/40 leading-relaxed mb-6">{plan.subtitle}</p>

          <div class="font-serif text-[38px] md:text-[44px] font-black leading-none text-white mb-1">
            {plan.price}
          </div>
          <div class="text-[12px] text-white/40 mb-8">{plan.period}</div>

          <ul class="flex flex-col gap-3.5 mb-8 flex-1">
            {plan.features.map((f) => (
              <li class="flex items-start gap-3 text-[13px] text-white/75 leading-snug">
                <span class="text-gold text-[8px] mt-1.5 flex-shrink-0">◆</span>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaHref ?? '#contact'}
            class={[
              'block w-full py-3.5 text-center text-[12px] font-semibold tracking-[0.15em] uppercase no-underline transition-all duration-300',
              plan.featured
                ? 'bg-gold text-ink hover:bg-gold-light hover:shadow-[0_10px_30px_rgba(201,168,76,0.25)]'
                : 'border border-white/30 text-white/70 hover:border-gold hover:text-gold',
            ].join(' ')}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
