---
const pillars = [
  {
    num: '01',
    titleAccent: 'EA ',
    titleRest: 'Trading',
    desc: 'Hệ thống giao dịch tự động với quản lý vốn chặt chẽ. Lợi nhuận ổn định, không cờ bạc "all-in".',
  },
  {
    num: '02',
    titleAccent: 'Weekly',
    titleRest: ' Analysis',
    desc: 'Phân tích thị trường chuyên sâu hàng tuần. Định hướng rõ ràng cho mọi trader. Tránh giao dịch cảm tính.',
  },
  {
    num: '03',
    titleAccent: 'Education',
    titleRest: ' System',
    desc: 'Nội dung chất lượng trên Facebook, YouTube, TikTok. Từ cơ bản đến nâng cao theo lộ trình rõ ràng.',
  },
  {
    num: '04',
    titleAccent: 'Training',
    titleRest: ' & Team',
    desc: 'Đào tạo trader mới. Hướng dẫn xây dựng đội nhóm chuyên nghiệp. Phát triển kỹ năng lãnh đạo và hệ thống.',
  },
  {
    num: '05',
    titleAccent: 'Strategic',
    titleRest: ' Partnerships',
    desc: 'Kết nối với broker và nền tảng giao dịch uy tín dựa trên kinh nghiệm thực tế. Giảm rủi ro cho người mới.',
  },
  {
    num: '06',
    titleAccent: 'Events',
    titleRest: ' & Engagement',
    desc: 'Workshop, Webinar, Seminar offline. Biến kiến thức thành trải nghiệm thực tế, không chỉ lý thuyết.',
  },
];
---

<section id="pillars" class="relative z-10 border-b border-white/10 px-6 md:px-16 py-16 md:py-28">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-16 md:mb-20 reveal">
      <div>
        <span class="section-label mb-4">// 02 — Dịch vụ</span>
        <h2 class="section-title">
          6 Trụ cột<br /><span class="text-gold italic font-normal">hoạt động</span>
        </h2>
      </div>
      <p class="mt-6 md:mt-0 text-sm text-white/40 md:max-w-[260px] md:text-right leading-relaxed">
        Từ tự động hoá đến giáo dục, từ phân tích đến xây dựng đội nhóm.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-3 gap-px bg-white/10">
      {pillars.map((p, i) => (
        <div
          class="group relative bg-ink px-6 py-8 md:px-10 md:py-12 overflow-hidden transition-colors duration-300 hover:bg-ink-2 reveal"
          style={`animation-delay: ${i * 0.08}s`}
        >
          <!-- Bottom gradient line -->
          <span
            class="absolute bottom-0 left-10 right-10 h-px
                   bg-gradient-to-r from-transparent via-gold to-transparent
                   scale-x-0 group-hover:scale-x-100 transition-transform duration-400"
          ></span>

          <span
            class="block font-serif text-[68px] font-black leading-[0.85] mb-6
                   text-gold/10 group-hover:text-gold/20 transition-colors duration-300"
          >
            {p.num}
          </span>

          <div class="font-serif text-[21px] font-bold text-white mb-4">
            <span class="text-gold">{p.titleAccent}</span>{p.titleRest}
          </div>

          <p class="text-[14px] text-white/40 leading-[1.7]">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
