---
// Contact form powered by Formspree.
// 1. Sign up free at https://formspree.io
// 2. Create a new form and copy your form ID
// 3. Replace YOUR_FORM_ID below
const FORMSPREE_ID = 'mnjgwgek';
---

<section id="contact" class="relative z-10 border-b border-white/10 px-6 md:px-16 py-16 md:py-28">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 md:gap-20 items-start">

    <!-- Left: info -->
    <div class="reveal">
      <span class="section-label mb-4">// 05 — Liên hệ</span>
      <h2 class="section-title">
        Hãy bắt đầu<br />
        <span class="text-gold italic font-normal">cuộc trò chuyện.</span>
      </h2>
      <p class="mt-6 text-[16px] leading-relaxed text-white/60 font-light max-w-sm">
        Muốn tham gia cộng đồng, đăng ký hoàn phí giao dịch, hay cần tư vấn đầu tư cá nhân — đội ngũ NEXT 1 luôn sẵn sàng đồng hành.
      </p>

      <div class="mt-10 flex flex-col gap-5">
        <a href="mailto:admin.next1@gmail.com"
           class="flex items-center gap-4 group no-underline">
          <span class="w-10 h-10 border border-white/10 flex items-center justify-center text-gold
                       group-hover:border-gold transition-colors duration-200 flex-shrink-0">✉</span>
          <span class="text-[14px] text-white/60 group-hover:text-white transition-colors duration-200">
            admin.next1@gmail.com
          </span>
        </a>
        <a href="https://t.me/next1community" target="_blank" rel="noopener"
           class="flex items-center gap-4 group no-underline">
          <span class="w-10 h-10 border border-white/10 flex items-center justify-center text-gold
                       group-hover:border-gold transition-colors duration-200 flex-shrink-0">✈</span>
          <span class="text-[14px] text-white/60 group-hover:text-white transition-colors duration-200">
            Telegram Community
          </span>
        </a>
        <a href="https://facebook.com/next1community" target="_blank" rel="noopener"
           class="flex items-center gap-4 group no-underline">
          <span class="w-10 h-10 border border-white/10 flex items-center justify-center text-gold
                       group-hover:border-gold transition-colors duration-200 flex-shrink-0">f</span>
          <span class="text-[14px] text-white/60 group-hover:text-white transition-colors duration-200">
            Facebook Group
          </span>
        </a>
      </div>
    </div>

    <!-- Right: form -->
    <div class="reveal" style="animation-delay: 0.15s">
      <form
        id="contact-form"
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="flex flex-col gap-4"
        novalidate
      >
        <!-- Name + Email -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] tracking-[0.2em] uppercase text-white/40">Họ và tên *</label>
            <input
              type="text" name="name" required placeholder="Nguyễn Văn A"
              class="bg-ink border border-white/10 px-4 py-3 text-[14px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60
                     transition-colors duration-200 w-full"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] tracking-[0.2em] uppercase text-white/40">Email *</label>
            <input
              type="email" name="email" required placeholder="email@example.com"
              class="bg-ink border border-white/10 px-4 py-3 text-[14px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60
                     transition-colors duration-200 w-full"
            />
          </div>
        </div>

        <!-- Phone + Interest -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] tracking-[0.2em] uppercase text-white/40">Số điện thoại</label>
            <input
              type="tel" name="phone" placeholder="0912 345 678"
              class="bg-ink border border-white/10 px-4 py-3 text-[14px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60
                     transition-colors duration-200 w-full"
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] tracking-[0.2em] uppercase text-white/40">Quan tâm đến</label>
            <div class="relative">
              <select
                name="interest"
                class="bg-ink border border-white/10 px-4 py-3 text-[14px] text-white/90
                       focus:outline-none focus:border-gold/60 transition-colors duration-200
                       w-full appearance-none cursor-pointer"
              >
                <option value="community">Cộng đồng chuyên nghiệp (Miễn phí)</option>
                <option value="cashback">Cashback — Hoàn phí giao dịch</option>
                <option value="investing">Investing Advice — Tư vấn đầu tư</option>
                <option value="partnership">Hợp tác / Partnership</option>
                <option value="other">Khác</option>
              </select>
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gold/60 pointer-events-none text-[10px]">▼</span>
            </div>
          </div>
        </div>

        <!-- Message -->
        <div class="flex flex-col gap-1.5">
          <label class="text-[11px] tracking-[0.2em] uppercase text-white/40">Lời nhắn *</label>
          <textarea
            name="message" required rows="5"
            placeholder="Cho chúng tôi biết bạn muốn hỏi gì..."
            class="bg-ink border border-white/10 px-4 py-3 text-[14px] text-white/90
                   placeholder:text-white/20 focus:outline-none focus:border-gold/60
                   transition-colors duration-200 w-full resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          id="submit-btn"
          type="submit"
          class="mt-2 w-full py-4 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
                 transition-all duration-300 hover:bg-gold-light hover:shadow-[0_10px_40px_rgba(201,168,76,0.3)]
                 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Gửi tin nhắn
        </button>

        <!-- Success / error states -->
        <p id="form-success" class="hidden text-center text-emerald-400 text-[14px] py-2">
          ✓ Đã gửi thành công — chúng tôi sẽ liên hệ sớm nhất có thể.
        </p>
        <p id="form-error" class="hidden text-center text-red-400 text-[14px] py-2">
          Có lỗi xảy ra. Vui lòng thử lại hoặc gửi email trực tiếp.
        </p>
      </form>
    </div>

  </div>
</section>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const btn     = document.getElementById('submit-btn')   as HTMLButtonElement;
  const success = document.getElementById('form-success') as HTMLElement;
  const error   = document.getElementById('form-error')   as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled    = true;
    btn.textContent = 'Đang gửi...';
    success.classList.add('hidden');
    error.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method:  'POST',
        body:    new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        success.classList.remove('hidden');
        btn.textContent = 'Gửi tin nhắn';
      } else {
        throw new Error();
      }
    } catch {
      error.classList.remove('hidden');
      btn.textContent = 'Gửi tin nhắn';
    } finally {
      btn.disabled = false;
    }
  });
</script>
