---
const items = [
  { symbol: 'BTC/USD',  key: 'btcusdt',  dec: 0 },
  { symbol: 'ETH/USD',  key: 'ethusdt',  dec: 1 },
  { symbol: 'SOL/USD',  key: 'solusdt',  dec: 2 },
  { symbol: 'BNB/USD',  key: 'bnbusdt',  dec: 1 },
  { symbol: 'XRP/USD',  key: 'xrpusdt',  dec: 4 },
  { symbol: 'DOGE/USD', key: 'dogeusdt', dec: 5 },
  { symbol: 'ADA/USD',  key: 'adausdt',  dec: 4 },
  { symbol: 'AVAX/USD', key: 'avaxusdt', dec: 2 },
  { symbol: 'LINK/USD', key: 'linkusdt', dec: 2 },
  { symbol: 'DOT/USD',  key: 'dotusdt',  dec: 3 },
  { symbol: 'LTC/USD',  key: 'ltcusdt',  dec: 2 },
  { symbol: 'UNI/USD',  key: 'uniusdt',  dec: 2 },
  { symbol: 'NEAR/USD', key: 'nearusdt', dec: 3 },
  { symbol: 'APT/USD',  key: 'aptusdt',  dec: 2 },
  { symbol: 'SUI/USD',  key: 'suiusdt',  dec: 3 },
  { symbol: 'OP/USD',   key: 'opusdt',   dec: 3 },
  { symbol: 'ARB/USD',  key: 'arbusdt',  dec: 4 },
  { symbol: 'ATOM/USD', key: 'atomusdt', dec: 2 },
  { symbol: 'PEPE/USD', key: 'pepeusdt', dec: 8 },
  { symbol: 'TON/USD',  key: 'tonusdt',  dec: 3 },
];

const doubled = [...items, ...items];
---

<div class="relative z-10 bg-ink-2 border-y border-white/10 py-[13px] overflow-hidden">
  <div class="flex gap-16 whitespace-nowrap animate-ticker w-max">
    {doubled.map((item) => (
      <div class="flex items-center gap-2.5 font-mono text-[12px] text-white/40" data-ticker={item.key}>
        <span class="text-white/80 font-medium">{item.symbol}</span>
        <span class="ticker-price">—</span>
        <span class="ticker-change">—</span>
      </div>
    ))}
  </div>
</div>

<script>
  const DECIMALS: Record<string, number> = {
    btcusdt: 0,  ethusdt: 1,  solusdt: 2,  bnbusdt: 1,
    xrpusdt: 4,  dogeusdt: 5, adausdt: 4,  avaxusdt: 2,
    linkusdt: 2, dotusdt: 3,  ltcusdt: 2,  uniusdt: 2,
    nearusdt: 3, aptusdt: 2,  suiusdt: 3,  opusdt: 3,
    arbusdt: 4,  atomusdt: 2, pepeusdt: 8, tonusdt: 3,
  };

  function fmt(value: number, key: string): string {
    const d = DECIMALS[key] ?? 2;
    return value.toLocaleString('en-US', { minimumFractionDigits: d, maximumFractionDigits: d });
  }

  function updateTicker(key: string, price: string, change: string, up: boolean) {
    document.querySelectorAll<HTMLElement>(`[data-ticker="${key}"]`).forEach((el) => {
      const priceEl  = el.querySelector('.ticker-price');
      const changeEl = el.querySelector('.ticker-change');
      if (priceEl)  priceEl.textContent = price;
      if (changeEl) {
        changeEl.textContent = change;
        changeEl.className   = `ticker-change ${up ? 'text-emerald-400' : 'text-red-400'}`;
      }
    });
  }

  const streams = Object.keys(DECIMALS).map(s => `${s}@miniTicker`).join('/');

  function connect() {
    const ws = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${streams}`);

    ws.onmessage = (e) => {
      const { stream, data } = JSON.parse(e.data);
      const key   = stream.replace('@miniTicker', '');
      const price = parseFloat(data.c);
      const open  = parseFloat(data.o);
      const pct   = ((price - open) / open) * 100;
      const up    = pct >= 0;
      updateTicker(key, fmt(price, key), `${up ? '+' : ''}${pct.toFixed(2)}%`, up);
    };

    ws.onclose = () => setTimeout(connect, 5000);
    ws.onerror = () => ws.close();
  }

  connect();
</script>
