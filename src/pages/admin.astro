  .prose-next1 { color: rgba(255,255,255,0.75); font-family: 'DM Sans', sans-serif; font-weight: 300; font-size: 16px; line-height: 1.85; }
  .prose-next1 h2 { font-family: 'Playfair Display', serif; font-size: clamp(22px, 3vw, 30px); font-weight: 700; color: #fff; margin-top: 2.5em; margin-bottom: 0.75em; line-height: 1.2; }
  .prose-next1 h3 { font-family: 'Playfair Display', serif; font-size: clamp(18px, 2.5vw, 22px); font-weight: 700; color: rgba(255,255,255,0.9); margin-top: 2em; margin-bottom: 0.5em; }
  .prose-next1 p { margin-bottom: 1.4em; }
  .prose-next1 a { color: #C9A84C; text-decoration: underline; text-underline-offset: 3px; }
  .prose-next1 strong { color: #fff; font-weight: 600; }
  .prose-next1 em { font-style: italic; color: rgba(255,255,255,0.85); }
  .prose-next1 blockquote { border-left: 2px solid #C9A84C; padding-left: 1.25rem; margin: 2em 0; color: rgba(255,255,255,0.5); font-style: italic; font-family: 'Playfair Display', serif; font-size: 1.05em; }
  .prose-next1 ul { list-style: none; padding: 0; margin-bottom: 1.4em; }
  .prose-next1 ul li { padding-left: 1.25em; position: relative; margin-bottom: 0.4em; }
  .prose-next1 ul li::before { content: '—'; position: absolute; left: 0; color: #C9A84C; font-weight: 400; }
  .prose-next1 ol { padding-left: 1.5em; margin-bottom: 1.4em; }
  .prose-next1 ol li { margin-bottom: 0.4em; }
</style>

<script define:vars={{ PROJECT_ID, DATASET, TOKEN, DEPLOY_HOOK }}>
  const API      = `https://${PROJECT_ID}.api.sanity.io/v2024-01-01/data`;
  const ASSETS   = `https://${PROJECT_ID}.api.sanity.io/v2024-01-01/assets/images/${DATASET}`;
  const HEADERS  = { 'Content-Type': 'application/json', 'Authorization': `Bearer ${TOKEN}` };
  const PASSWORD = 'next1admin2026';

  // ── GATE ──
  const gate = document.getElementById('gate');
  const panel = document.getElementById('panel');
  document.getElementById('pwd-btn').addEventListener('click', tryLogin);
  document.getElementById('pwd').addEventListener('keydown', e => { if (e.key === 'Enter') tryLogin(); });

  function tryLogin() {
    if (document.getElementById('pwd').value === PASSWORD) {
      gate.style.display = 'none';
      panel.classList.remove('hidden');
      loadPosts();
      updateDraftBadge();
      checkAutosaveRestore();
    } else {
      document.getElementById('pwd-err').classList.remove('hidden');
      document.getElementById('pwd').value = '';
    }
  }

  // ── TABS ──
  const TABS = ['write', 'ai', 'posts', 'drafts', 'broker-list', 'broker-form'];
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab;
      TABS.forEach(t => document.getElementById(`tab-${t}`)?.classList.toggle('hidden', t !== tab));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active-tab'));
      document.querySelectorAll(`[data-tab="${tab}"]`).forEach(b => b.classList.add('active-tab'));
      if (tab === 'posts')       loadPosts();
      if (tab === 'drafts')      loadDrafts();
      if (tab === 'broker-list') loadBrokers();
    });
  });

  // ── SLUG AUTO-GENERATE ──
  document.getElementById('f-title').addEventListener('input', e => {
    if (document.getElementById('edit-id').value) return;
    document.getElementById('f-slug').value = slugify(e.target.value);
  });

  // Broker: auto-generate slug from name
  document.getElementById('b-name').addEventListener('input', e => {
    if (document.getElementById('broker-edit-id').value) return; // skip if editing
    document.getElementById('b-slug').value = slugify(e.target.value);
  });

  function slugify(str) {
    return str.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/đ/g, 'd').replace(/[^a-z0-9\s-]/g, '')
      .trim().replace(/\s+/g, '-');
  }

  // ── WYSIWYG TOOLBAR ──
  document.querySelectorAll('.wysiwyg-btn[data-exec]').forEach(btn => {
    btn.addEventListener('mousedown', e => {
      e.preventDefault(); // keep editor focus
      const cmd = btn.dataset.exec;
      const val = btn.dataset.val || null;
      document.execCommand(cmd, false, val);
      document.getElementById('f-body').focus();
    });
  });

  // Link button
  document.getElementById('btn-link').addEventListener('mousedown', e => {
    e.preventDefault();
    const url = prompt('Nhập URL đường link:');
    if (url) {
      document.execCommand('createLink', false, url);
      // Make links open in new tab
      document.querySelectorAll('#f-body a').forEach(a => {
        a.target = '_blank'; a.rel = 'noopener noreferrer';
      });
    }
    document.getElementById('f-body').focus();
  });

  // Keyboard shortcuts
  document.getElementById('f-body').addEventListener('keydown', e => {
    if (e.ctrlKey || e.metaKey) {
      if (e.key === 'b') { e.preventDefault(); document.execCommand('bold'); }
      if (e.key === 'i') { e.preventDefault(); document.execCommand('italic'); }
      if (e.key === 'u') { e.preventDefault(); document.execCommand('underline'); }
    }
  });

  // ── HTML ↔ SANITY BLOCKS ──
  function editorKey() { return Math.random().toString(36).slice(2, 10); }

  function htmlToBlocks(html) {
    if (!html || !html.trim()) return [];
    const div = document.createElement('div');
    div.innerHTML = html;
    const blocks = [];

    function spansFromNode(node) {
      const result = [];
      function walk(n, marks) {
        if (n.nodeType === 3 /* TEXT */) {
          if (n.textContent) result.push({ _type:'span', _key:editorKey(), text:n.textContent, marks:[...marks] });
        } else if (n.nodeType === 1 /* ELEMENT */) {
          const t = n.tagName.toLowerCase();
          const m = [...marks];
          if (t==='b'||t==='strong') m.push('strong');
          else if (t==='i'||t==='em') m.push('em');
          else if (t==='u') m.push('underline');
          else if (t==='s'||t==='strike'||t==='del') m.push('strike-through');
          n.childNodes.forEach(c => walk(c, m));
        }
      }
      walk(node, []);
      return result.length ? result : [{ _type:'span', _key:editorKey(), text:'', marks:[] }];
    }

    function blockFrom(node, style, listItem, level) {
      return { _type:'block', _key:editorKey(), style, markDefs:[], listItem, level,
               children: spansFromNode(node) };
    }

    let i = 0;
    const nodes = Array.from(div.childNodes);
    while (i < nodes.length) {
      const n = nodes[i];
      if (n.nodeType === 3) { // bare text
        if (n.textContent.trim()) blocks.push(blockFrom(n, 'normal', undefined, undefined));
        i++; continue;
      }
      if (n.nodeType !== 1) { i++; continue; }
      const tag = n.tagName.toLowerCase();
      if (tag === 'h1')         { blocks.push(blockFrom(n,'h1',undefined,undefined)); }
      else if (tag === 'h2')    { blocks.push(blockFrom(n,'h2',undefined,undefined)); }
      else if (tag === 'h3')    { blocks.push(blockFrom(n,'h3',undefined,undefined)); }
      else if (tag === 'blockquote') { blocks.push(blockFrom(n,'blockquote',undefined,undefined)); }
      else if (tag === 'ul') {
        n.querySelectorAll('li').forEach(li => blocks.push(blockFrom(li,'normal','bullet',1)));
      }
      else if (tag === 'ol') {
        n.querySelectorAll('li').forEach(li => blocks.push(blockFrom(li,'normal','number',1)));
      }
      else if (tag === 'hr') { /* skip */ }
      else if (tag === 'br') { /* skip */ }
      else { // p, div, span, etc.
        const spans = spansFromNode(n);
        if (spans.some(s => s.text.trim())) blocks.push({ _type:'block', _key:editorKey(), style:'normal', markDefs:[], children:spans });
      }
      i++;
    }
    return blocks;
  }

  function blocksToHtml(blocks) {
    if (!blocks?.length) return '';
    let html = '';
    let i = 0;
    while (i < blocks.length) {
      const b = blocks[i];
      const inner = spansToHtml(b.children ?? []);
      if (b.listItem === 'bullet') {
        let items = `<li>${inner}</li>`;
        while (blocks[i+1]?.listItem === 'bullet') { i++; items += `<li>${spansToHtml(blocks[i].children??[])}</li>`; }
        html += `<ul>${items}</ul>`;
      } else if (b.listItem === 'number') {
        let items = `<li>${inner}</li>`;
        while (blocks[i+1]?.listItem === 'number') { i++; items += `<li>${spansToHtml(blocks[i].children??[])}</li>`; }
        html += `<ol>${items}</ol>`;
      } else if (b.style === 'h1') html += `<h1>${inner || '<br>'}</h1>`;
      else if (b.style === 'h2') html += `<h2>${inner || '<br>'}</h2>`;
      else if (b.style === 'h3') html += `<h3>${inner || '<br>'}</h3>`;
      else if (b.style === 'blockquote') html += `<blockquote>${inner || '<br>'}</blockquote>`;
      else html += `<p>${inner || '<br>'}</p>`;
      i++;
    }
    return html;
  }

  function spansToHtml(spans) {
    return spans.map(s => {
      let t = (s.text ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const m = s.marks ?? [];
      if (m.includes('strong')) t = `<strong>${t}</strong>`;
      if (m.includes('em'))     t = `<em>${t}</em>`;
      if (m.includes('underline')) t = `<u>${t}</u>`;
      if (m.includes('strike-through')) t = `<s>${t}</s>`;
      return t;
    }).join('');
  }

  function getEditorHtml() { return document.getElementById('f-body').innerHTML; }
  function setEditorHtml(html) { document.getElementById('f-body').innerHTML = html || ''; }

  // ── AUTO-SAVE TO LOCALSTORAGE ──
  const AUTOSAVE_KEY = 'next1_admin_autosave';
  let autosaveTimer  = null;

  function getFormSnapshot() {
    return {
      title:    document.getElementById('f-title').value,
      slug:     document.getElementById('f-slug').value,
      excerpt:  document.getElementById('f-excerpt').value,
      category: document.getElementById('f-category').value,
      author:   document.getElementById('f-author').value,
      bodyHtml: getEditorHtml(),
      editId:   document.getElementById('edit-id').value,
      savedAt:  new Date().toISOString(),
    };
  }

  function triggerAutosave() {
    clearTimeout(autosaveTimer);
    autosaveTimer = setTimeout(() => {
      const snap = getFormSnapshot();
      if (!snap.title && !snap.bodyHtml) return;
      localStorage.setItem(AUTOSAVE_KEY, JSON.stringify(snap));
      const el = document.getElementById('autosave-status');
      el.textContent = `Tự lưu lúc ${new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' })}`;
      setTimeout(() => { el.textContent = ''; }, 3000);
    }, 30000);
  }

  // Attach autosave triggers
  ['f-title','f-slug','f-excerpt','f-author'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', triggerAutosave);
  });
  document.getElementById('f-body')?.addEventListener('input', triggerAutosave);
  document.getElementById('f-category')?.addEventListener('change', triggerAutosave);

  // Restore autosave on page load (only if not already editing)
  function checkAutosaveRestore() {
    const raw = localStorage.getItem(AUTOSAVE_KEY);
    if (!raw) return;
    try {
      const snap = JSON.parse(raw);
      if (!snap.title && !snap.body) return;
      const when = new Date(snap.savedAt).toLocaleString('vi-VN');
      const banner = document.createElement('div');
      banner.id = 'autosave-banner';
      banner.className = 'flex items-center justify-between gap-4 bg-gold/10 border border-gold/30 px-4 py-3 mb-6 text-[13px]';
      banner.innerHTML = `
        <span class="text-white/70">💾 Có bản nháp chưa lưu từ <strong class="text-white">${when}</strong></span>
        <div class="flex gap-2 flex-shrink-0">
          <button id="autosave-restore" class="font-mono text-[11px] tracking-[0.15em] uppercase text-gold hover:text-gold-light transition-colors">Khôi phục</button>
          <span class="text-white/20">·</span>
          <button id="autosave-discard" class="font-mono text-[11px] tracking-[0.15em] uppercase text-white/30 hover:text-white transition-colors">Bỏ qua</button>
        </div>`;
      const form = document.getElementById('post-form');
      form.parentNode.insertBefore(banner, form);

      document.getElementById('autosave-restore').addEventListener('click', () => {
        document.getElementById('f-title').value    = snap.title    || '';
        document.getElementById('f-slug').value     = snap.slug     || '';
        document.getElementById('f-excerpt').value  = snap.excerpt  || '';
        document.getElementById('f-category').value = snap.category || '';
        document.getElementById('f-author').value   = snap.author   || 'NEXT 1 Team';
        setEditorHtml(snap.bodyHtml || snap.body || '');
        if (snap.editId) document.getElementById('edit-id').value = snap.editId;
        banner.remove();
      });
      document.getElementById('autosave-discard').addEventListener('click', () => {
        localStorage.removeItem(AUTOSAVE_KEY);
        banner.remove();
      });
    } catch {}
  }

  // ── SAVE DRAFT (Sanity) ──
  document.getElementById('draft-btn').addEventListener('click', saveDraft);

  async function saveDraft() {
    const btn       = document.getElementById('draft-btn');
    const successEl = document.getElementById('draft-success');
    const errEl     = document.getElementById('form-error');
    const title     = document.getElementById('f-title').value.trim();
    if (!title) { errEl.textContent = 'Cần có tiêu đề để lưu nháp.'; errEl.classList.remove('hidden'); return; }

    btn.disabled = true; btn.textContent = 'Đang lưu...';
    successEl.classList.add('hidden'); errEl.classList.add('hidden');

    try {
      const assetId  = await uploadImageIfNeeded();
      const editId   = document.getElementById('edit-id').value;
      const slug     = document.getElementById('f-slug').value.trim() || slugify(title);
      const excerpt  = document.getElementById('f-excerpt').value.trim();
      const category = document.getElementById('f-category').value;
      const author   = document.getElementById('f-author').value.trim();
      const body     = htmlToBlocks(getEditorHtml());

      const doc = {
        title, excerpt, category, author, isDraft: true,
        slug: { _type: 'slug', current: slug },
        body,
      };
      if (assetId) doc.coverImage = { _type: 'image', asset: { _type: 'reference', _ref: assetId } };

      let mutations;
      if (editId) {
        mutations = [{ patch: { id: editId, set: doc } }];
      } else {
        mutations = [{ create: { _type: 'post', ...doc } }];
      }
      const res = await fetch(`${API}/mutate/${DATASET}`, {
        method: 'POST', headers: HEADERS,
        body: JSON.stringify({ mutations }),
      });
      if (!res.ok) throw new Error(await res.text());

      // If new draft, store its id for subsequent saves
      if (!editId) {
        const data = await res.json();
        const newId = data.results?.[0]?.id;
        if (newId) document.getElementById('edit-id').value = newId;
      }

      // Clear localStorage autosave now that it's in Sanity
      localStorage.removeItem(AUTOSAVE_KEY);
      successEl.classList.remove('hidden');
      updateDraftBadge();
    } catch (err) {
      errEl.textContent = 'Lỗi: ' + (err?.message ?? 'Thử lại.');
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false; btn.textContent = '💾 Lưu nháp';
    }
  }

  // ── LOAD DRAFTS ──
  async function loadDrafts() {
    const listEl = document.getElementById('draft-list');
    listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Đang tải...</p>';
    try {
      const q = encodeURIComponent('*[_type == "post" && isDraft == true] | order(_updatedAt desc) { _id, title, slug, _updatedAt, category, author }');
      const res = await fetch(`${API}/query/${DATASET}?query=${q}`, { headers: HEADERS });
      const { result } = await res.json();
      const drafts = result ?? [];
      updateDraftBadge(drafts.length);

      if (!drafts.length) {
        listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Chưa có bài nháp nào.</p>';
        return;
      }

      listEl.innerHTML = drafts.map(p => `
        <div class="flex items-center justify-between border border-white/10 border-l-2 border-l-gold/40 px-4 py-4 hover:border-white/20 transition-colors">
          <div class="flex-1 min-w-0 mr-4">
            <p class="text-[14px] text-white/90 truncate">${p.title ?? '(Chưa có tiêu đề)'}</p>
            <div class="flex items-center gap-2 mt-0.5">
              ${p.category ? `<span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">${p.category}</span><span class="text-white/20 text-[10px]">·</span>` : ''}
              <span class="font-mono text-[10px] text-white/30">Lưu lúc ${new Date(p._updatedAt).toLocaleString('vi-VN', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' })}</span>
            </div>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <button data-id="${p._id}" class="draft-edit-btn font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-gold transition-colors">Tiếp tục</button>
            <button data-id="${p._id}" data-title="${(p.title ?? '').replace(/"/g,'')}" class="draft-publish-btn font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-emerald-400 transition-colors">Đăng</button>
            <button data-id="${p._id}" class="delete-btn font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-red-400 transition-colors">Xóa</button>
          </div>
        </div>
      `).join('');

      document.querySelectorAll('.draft-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => loadForEdit(btn.dataset.id));
      });
      document.querySelectorAll('.draft-publish-btn').forEach(btn => {
        btn.addEventListener('click', () => publishDraft(btn.dataset.id));
      });
      document.querySelectorAll('#draft-list .delete-btn').forEach(btn => {
        btn.addEventListener('click', () => confirmDelete(btn.dataset.id, 'drafts'));
      });
    } catch {
      listEl.innerHTML = '<p class="text-red-400 text-[13px] font-mono">Không tải được danh sách.</p>';
    }
  }

  async function publishDraft(id) {
    const res = await fetch(`${API}/mutate/${DATASET}`, {
      method: 'POST', headers: HEADERS,
      body: JSON.stringify({ mutations: [{ patch: { id, set: { isDraft: false, publishedAt: new Date().toISOString() } } }] }),
    });
    if (res.ok) {
      if (DEPLOY_HOOK) fetch(DEPLOY_HOOK, { method: 'POST' }).catch(() => {});
      loadDrafts();
    }
  }

  function updateDraftBadge(count) {
    const badge = document.getElementById('draft-count-badge');
    if (!badge) return;
    if (count === undefined) {
      // Fetch count silently
      const q = encodeURIComponent('count(*[_type == "post" && isDraft == true])');
      fetch(`${API}/query/${DATASET}?query=${q}`, { headers: HEADERS })
        .then(r => r.json()).then(d => updateDraftBadge(d.result ?? 0)).catch(() => {});
      return;
    }
    if (count > 0) {
      badge.textContent = count;
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }

  // ── IMAGE UPLOAD ──
  let pendingImageFile = null;

  document.getElementById('f-image').addEventListener('change', e => {
    const file = e.target.files?.[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) {
      alert('Ảnh quá lớn (tối đa 5MB)');
      e.target.value = '';
      return;
    }
    pendingImageFile = file;
    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('image-preview').src = ev.target.result;
      document.getElementById('image-preview').classList.remove('hidden');
      document.getElementById('image-placeholder').classList.add('hidden');
      document.getElementById('image-clear').classList.remove('hidden');
    };
    reader.readAsDataURL(file);
    // Clear previously uploaded ref since we have a new file
    document.getElementById('f-image-ref').value = '';
  });

  document.getElementById('image-clear').addEventListener('click', () => {
    pendingImageFile = null;
    document.getElementById('f-image').value = '';
    document.getElementById('f-image-ref').value = '';
    document.getElementById('image-preview').classList.add('hidden');
    document.getElementById('image-preview').src = '';
    document.getElementById('image-placeholder').classList.remove('hidden');
    document.getElementById('image-clear').classList.add('hidden');
  });

  async function uploadImageIfNeeded() {
    // Already uploaded (edit mode with existing image)
    if (document.getElementById('f-image-ref').value) return document.getElementById('f-image-ref').value;
    if (!pendingImageFile) return null;

    const statusEl = document.getElementById('image-upload-status');
    statusEl.classList.remove('hidden');
    statusEl.textContent = 'Đang tải ảnh lên Sanity...';

    try {
      const res = await fetch(ASSETS, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${TOKEN}`,
          'Content-Type': pendingImageFile.type,
        },
        body: pendingImageFile,
      });
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      const assetId = data.document._id;
      statusEl.textContent = '✓ Ảnh đã tải lên';
      document.getElementById('f-image-ref').value = assetId;
      return assetId;
    } catch (err) {
      statusEl.textContent = '✗ Lỗi tải ảnh: ' + err.message;
      throw err;
    }
  }

  // ── SUBMIT ──
  document.getElementById('post-form').addEventListener('submit', async e => {
    e.preventDefault();
    await submitPost();
  });

  async function submitPost() {
    const btn     = document.getElementById('submit-btn');
    const success = document.getElementById('form-success');
    const errEl   = document.getElementById('form-error');
    btn.disabled = true; btn.textContent = 'Đang lưu...';
    success.classList.add('hidden'); errEl.classList.add('hidden');

    try {
      const assetId = await uploadImageIfNeeded();
      const editId   = document.getElementById('edit-id').value;
      const title    = document.getElementById('f-title').value.trim();
      const slug     = document.getElementById('f-slug').value.trim() || slugify(title);
      const excerpt  = document.getElementById('f-excerpt').value.trim();
      const category = document.getElementById('f-category').value;
      const author   = document.getElementById('f-author').value.trim();
      const body     = htmlToBlocks(getEditorHtml());

      const doc = {
        title, excerpt, category, author,
        slug: { _type: 'slug', current: slug },
        publishedAt: new Date().toISOString(),
        isDraft: false,
        body,
      };

      if (assetId) {
        doc.coverImage = {
          _type: 'image',
          asset: { _type: 'reference', _ref: assetId },
        };
      }

      let mutations;
      if (editId) {
        mutations = [{ patch: { id: editId, set: doc } }];
      } else {
        mutations = [{ create: { _type: 'post', ...doc } }];
      }

      const res = await fetch(`${API}/mutate/${DATASET}`, {
        method: 'POST', headers: HEADERS,
        body: JSON.stringify({ mutations }),
      });
      if (!res.ok) throw new Error(await res.text());
      if (DEPLOY_HOOK) {
        fetch(DEPLOY_HOOK, { method: 'POST' }).catch(() => {});
      }
      localStorage.removeItem(AUTOSAVE_KEY);
      updateDraftBadge();
      // Close preview modal if open
      document.getElementById('preview-modal').classList.add('hidden');
      success.classList.remove('hidden');
      resetForm();
    } catch (err) {
