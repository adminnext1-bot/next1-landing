---
import '../styles/global.css';
const PROJECT_ID   = import.meta.env.SANITY_PROJECT_ID ?? '';
const DATASET      = import.meta.env.SANITY_DATASET   ?? 'production';
const TOKEN        = import.meta.env.SANITY_TOKEN      ?? '';
const HAS_TOKEN    = TOKEN.length > 0;
const DEPLOY_HOOK  = 'https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/50db80aa-160a-48c9-8897-f250a5a7d545';
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NEXT 1 — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400&display=swap" rel="stylesheet" />
</head>
<body class="bg-ink text-white min-h-screen">

  <!-- ── GATE ── -->
  <div id="gate" class="fixed inset-0 bg-ink z-50 flex items-center justify-center px-6">
    <div class="w-full max-w-sm">
      <p class="font-mono text-[10px] tracking-[0.4em] uppercase text-gold mb-6 text-center">// NEXT 1</p>
      <h1 class="font-serif text-3xl font-bold text-center mb-8">Admin Panel</h1>
      <input id="pwd" type="password" placeholder="Mật khẩu..."
        class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
               placeholder:text-white/20 focus:outline-none focus:border-gold/60 mb-3" />
      <button id="pwd-btn"
        class="w-full py-3 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
               hover:bg-gold-light transition-all duration-300">
        Đăng nhập
      </button>
      <p id="pwd-err" class="hidden mt-3 text-center text-red-400 text-[13px]">Sai mật khẩu.</p>
    </div>
  </div>

  <!-- ── PANEL ── -->
  <div id="panel" class="hidden">

    <!-- Sidebar -->
    <aside class="fixed top-0 left-0 h-full w-56 bg-ink-2 border-r border-white/10 flex flex-col z-40">
      <div class="px-6 py-6 border-b border-white/10">
        <p class="font-serif text-lg font-bold">NEXT<span class="italic font-normal text-white">1</span></p>
        <p class="font-mono text-[9px] tracking-[0.3em] uppercase text-gold mt-0.5">Admin Panel</p>
      </div>
      <nav class="flex-1 px-3 py-4 flex flex-col gap-1">
        <button data-tab="write"
          class="tab-btn active-tab text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors">
          ✏️ Viết bài mới
        </button>
        <button data-tab="ai"
          class="tab-btn text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors text-white/50 hover:text-white">
          🤖 AI Viết bài
        </button>
        <button data-tab="drafts"
          class="tab-btn text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors text-white/50 hover:text-white">
          📝 Bài nháp <span id="draft-count-badge" class="hidden ml-1 px-1.5 py-0.5 bg-gold/20 text-gold text-[9px] font-mono rounded">0</span>
        </button>
        <button data-tab="posts"
          class="tab-btn text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors text-white/50 hover:text-white">
          📋 Quản lý bài viết
        </button>
        <div class="h-px bg-white/10 my-1"></div>
        <button data-tab="broker-list"
          class="tab-btn text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors text-white/50 hover:text-white">
          🏦 Sàn đối tác
        </button>
        <button data-tab="broker-form"
          class="tab-btn text-left px-3 py-2.5 text-[13px] font-medium rounded transition-colors text-white/50 hover:text-white">
          ➕ Thêm sàn mới
        </button>
      </nav>
      <div class="px-4 py-4 border-t border-white/10 flex flex-col gap-1.5">
        <p class={`font-mono text-[9px] tracking-[0.2em] ${HAS_TOKEN ? 'text-emerald-400' : 'text-red-400'}`}>
          {HAS_TOKEN ? '✓ Sanity OK' : '✗ Thiếu token'}
        </p>
        <p class={`font-mono text-[9px] tracking-[0.2em] ${PROJECT_ID ? 'text-emerald-400' : 'text-red-400'}`}>
          {PROJECT_ID ? `✓ Project: ${PROJECT_ID}` : '✗ Thiếu Project ID'}
        </p>
        <a href="/blog" target="_blank"
          class="font-mono text-[10px] tracking-[0.2em] uppercase text-white/30 hover:text-gold no-underline transition-colors mt-2">
          Xem Blog →
        </a>
        <a href="/brokers" target="_blank"
          class="font-mono text-[10px] tracking-[0.2em] uppercase text-white/30 hover:text-gold no-underline transition-colors">
          Xem Đối tác →
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="ml-56 min-h-screen px-8 py-10 max-w-3xl">

      <!-- ── TAB: WRITE ── -->
      <div id="tab-write">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-2xl font-bold" id="form-heading">Viết bài mới</h2>
          <span id="autosave-status" class="font-mono text-[10px] text-white/25 tracking-[0.15em]"></span>
        </div>

        <form id="post-form" class="flex flex-col gap-5">
          <input id="edit-id" type="hidden" value="" />

          <!-- Title -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tiêu đề *</label>
            <input id="f-title" type="text" required placeholder="Tiêu đề bài viết..."
              class="bg-ink-2 border border-white/10 px-4 py-3 text-[15px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60" />
          </div>

          <!-- Slug -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Đường dẫn URL</label>
            <input id="f-slug" type="text" placeholder="tu-dong-tao-tu-tieu-de"
              class="bg-ink-2 border border-white/10 px-4 py-3 text-[13px] text-white/50 font-mono
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60" />
          </div>

          <!-- Excerpt -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tóm tắt</label>
            <textarea id="f-excerpt" rows="2" placeholder="Mô tả ngắn hiện trên trang danh sách..."
              class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60 resize-none"></textarea>
          </div>

          <!-- Cover Image Upload -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Ảnh bìa</label>
            <div id="image-drop-zone"
              class="relative border border-dashed border-white/20 hover:border-gold/40 transition-colors cursor-pointer overflow-hidden">
              <input id="f-image" type="file" accept="image/*"
                class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10" />
              <div id="image-placeholder" class="flex flex-col items-center justify-center py-10 gap-2 pointer-events-none">
                <span class="text-3xl opacity-30">🖼</span>
                <p class="font-mono text-[11px] text-white/30 tracking-[0.2em] uppercase">Click hoặc kéo thả ảnh vào đây</p>
                <p class="font-mono text-[10px] text-white/20">JPG, PNG, WebP · Tối đa 5MB</p>
              </div>
              <img id="image-preview" class="hidden w-full max-h-52 object-cover" alt="Preview" />
              <button id="image-clear" type="button"
                class="hidden absolute top-2 right-2 z-20 bg-black/60 hover:bg-black/80 text-white text-[11px]
                       px-2 py-1 font-mono tracking-widest transition-colors">
                ✕ Xóa
              </button>
            </div>
            <div id="image-upload-status" class="hidden font-mono text-[10px] text-white/40">Đang tải ảnh lên...</div>
            <input id="f-image-ref" type="hidden" value="" />
            <!-- AI Generate Image button -->
            <button id="ai-image-btn" type="button"
              class="flex items-center gap-2 w-fit font-mono text-[11px] tracking-[0.2em] uppercase
                     text-white/40 hover:text-gold transition-colors mt-1">
              ✨ AI tạo ảnh từ tiêu đề
            </button>
          </div>

          <!-- AI Image Panel (inline, toggles) -->
          <div id="ai-image-panel" class="hidden flex flex-col gap-3 border border-gold/20 bg-gold/[0.03] p-4">
            <div class="flex items-center justify-between">
              <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-gold">✨ DALL-E 3 — Tạo ảnh bìa</p>
              <button id="ai-image-close" type="button" class="font-mono text-[10px] text-white/30 hover:text-white transition-colors">✕ Đóng</button>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[9px] tracking-[0.25em] uppercase text-white/30">Prompt (có thể chỉnh sửa)</label>
              <textarea id="ai-image-prompt" rows="5"
                class="bg-ink-2 border border-white/10 px-4 py-3 text-[13px] text-white/80 font-mono leading-relaxed
                       placeholder:text-white/20 focus:outline-none focus:border-gold/40 resize-y"></textarea>
            </div>
            <div class="flex gap-3 items-center">
              <button id="ai-image-generate" type="button"
                class="px-5 py-2.5 bg-gold text-ink text-[11px] font-semibold tracking-[0.15em] uppercase
                       hover:bg-gold-light transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
                Tạo ảnh
              </button>
              <button id="ai-image-regen" type="button"
                class="hidden px-4 py-2.5 border border-white/20 text-white/50 text-[11px] font-mono tracking-widest uppercase
                       hover:border-white/40 hover:text-white transition-colors">
                Tạo lại
              </button>
              <span id="ai-image-status" class="font-mono text-[11px] text-white/40"></span>
            </div>
            <!-- Generated image preview -->
            <div id="ai-image-result" class="hidden flex flex-col gap-3">
              <img id="ai-image-out" src="" alt="Generated"
                class="w-full aspect-[16/9] object-cover border border-white/10" />
              <button id="ai-image-use" type="button"
                class="w-full py-3 border border-gold/40 text-gold text-[11px] font-mono tracking-[0.2em] uppercase
                       hover:bg-gold/10 transition-all duration-300">
                ✓ Dùng ảnh này làm ảnh bìa
              </button>
            </div>
            <p id="ai-image-error" class="hidden text-red-400 text-[12px] font-mono"></p>
          </div>

          <!-- Category + Author -->
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Danh mục</label>
              <div class="relative">
                <select id="f-category"
                  class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                         focus:outline-none focus:border-gold/60 appearance-none cursor-pointer">
                  <option value="">— Chọn danh mục —</option>
                  <option value="Phân tích thị trường">Phân tích thị trường</option>
                  <option value="Chiến lược giao dịch">Chiến lược giao dịch</option>
                  <option value="Tư duy đầu tư">Tư duy đầu tư</option>
                  <option value="Giáo dục tài chính">Giáo dục tài chính</option>
                  <option value="Tin tức & Cập nhật">Tin tức & Cập nhật</option>
                </select>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gold/60 pointer-events-none text-[10px]">▼</span>
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tác giả</label>
              <input id="f-author" type="text" value="NEXT 1 Team"
                class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                       focus:outline-none focus:border-gold/60" />
            </div>
          </div>

          <!-- WYSIWYG Editor -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Nội dung *</label>
            <div id="editor-wrap" class="border border-white/10 focus-within:border-gold/60 transition-colors">

              <!-- Toolbar row 1: Kiểu văn bản -->
              <div class="flex flex-wrap gap-px px-2 pt-2 pb-1 border-b border-white/10 bg-ink-3">
                <span class="font-mono text-[9px] tracking-widest uppercase text-white/20 self-center px-1 mr-1">Kiểu:</span>
                <button type="button" data-exec="formatBlock" data-val="p"
                  title="Văn bản thường"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  ¶ Thường
                </button>
                <button type="button" data-exec="formatBlock" data-val="h2"
                  title="Tiêu đề lớn"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[13px] font-bold text-white/50 hover:text-gold hover:bg-white/8 rounded transition-colors">
                  H2
                </button>
                <button type="button" data-exec="formatBlock" data-val="h3"
                  title="Tiêu đề vừa"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] font-bold text-white/50 hover:text-gold hover:bg-white/8 rounded transition-colors">
                  H3
                </button>
                <button type="button" data-exec="formatBlock" data-val="blockquote"
                  title="Trích dẫn"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] text-white/50 hover:text-gold hover:bg-white/8 rounded transition-colors">
                  ❝ Trích dẫn
                </button>

                <span class="w-px bg-white/10 mx-1 self-stretch"></span>
                <span class="font-mono text-[9px] tracking-widest uppercase text-white/20 self-center px-1 mr-1">Định dạng:</span>

                <button type="button" data-exec="bold"
                  title="In đậm (Ctrl+B)"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[13px] font-bold text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  B
                </button>
                <button type="button" data-exec="italic"
                  title="In nghiêng (Ctrl+I)"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[13px] italic text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  I
                </button>
                <button type="button" data-exec="underline"
                  title="Gạch chân (Ctrl+U)"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[13px] underline text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  U
                </button>
                <button type="button" data-exec="strikeThrough"
                  title="Gạch ngang"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[13px] line-through text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  S
                </button>

                <span class="w-px bg-white/10 mx-1 self-stretch"></span>
                <span class="font-mono text-[9px] tracking-widest uppercase text-white/20 self-center px-1 mr-1">Danh sách:</span>

                <button type="button" data-exec="insertUnorderedList"
                  title="Danh sách dấu chấm"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  • Chấm
                </button>
                <button type="button" data-exec="insertOrderedList"
                  title="Danh sách đánh số"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] text-white/50 hover:text-white hover:bg-white/8 rounded transition-colors">
                  1. Số
                </button>

                <span class="w-px bg-white/10 mx-1 self-stretch"></span>

                <button type="button" id="btn-link"
                  title="Chèn đường link"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[12px] text-white/50 hover:text-gold hover:bg-white/8 rounded transition-colors">
                  🔗 Link
                </button>
                <button type="button" data-exec="removeFormat"
                  title="Xóa toàn bộ định dạng của đoạn đang chọn"
                  class="wysiwyg-btn px-2.5 py-1.5 text-[11px] text-white/30 hover:text-red-400 hover:bg-white/8 rounded transition-colors">
                  ✕ Xóa định dạng
                </button>
              </div>

              <!-- Contenteditable editor -->
              <div
                id="f-body"
                contenteditable="true"
                data-placeholder="Bắt đầu soạn nội dung bài viết tại đây...&#10;&#10;Chọn văn bản rồi nhấn các nút trên để định dạng — đậm, nghiêng, tiêu đề, danh sách..."
                class="wysiwyg-editor min-h-[320px] px-6 py-5 focus:outline-none"
              ></div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex gap-3 mt-2 flex-wrap">
            <button id="preview-btn" type="button"
              class="px-5 py-4 border border-white/20 text-white/60 text-[12px] font-medium tracking-[0.1em] uppercase
                     hover:border-gold/40 hover:text-gold transition-all duration-300">
              👁 Xem trước
            </button>
            <button id="draft-btn" type="button"
              class="px-5 py-4 border border-white/20 text-white/60 text-[12px] font-medium tracking-[0.1em] uppercase
                     hover:border-white/40 hover:text-white transition-all duration-300">
              💾 Lưu nháp
            </button>
            <button id="submit-btn" type="submit"
              class="flex-1 py-4 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
                     hover:bg-gold-light transition-all duration-300 disabled:opacity-50">
              Đăng bài
            </button>
            <button id="cancel-edit" type="button"
              class="hidden px-5 py-4 border border-white/20 text-white/60 text-[12px] font-medium tracking-[0.1em] uppercase
                     hover:border-white/40 hover:text-white transition-all duration-300">
              Hủy
            </button>
          </div>

          <p id="form-success" class="hidden text-center text-emerald-400 text-[14px] py-2">✓ Đăng thành công! Blog đang rebuild (~1 phút).</p>
          <p id="draft-success" class="hidden text-center text-white/50 text-[14px] py-2">💾 Đã lưu nháp.</p>
          <p id="form-error"    class="hidden text-center text-red-400 text-[14px] py-2">Có lỗi xảy ra. Thử lại.</p>
        </form>
      </div>

      <!-- ── TAB: AI ── -->
      <div id="tab-ai" class="hidden">
        <div class="mb-8">
          <h2 class="font-serif text-2xl font-bold">AI Viết bài</h2>
          <p class="text-white/40 text-[13px] mt-1">Claude AI sẽ tự động tạo bài viết hoàn chỉnh theo chủ đề bạn nhập.</p>
        </div>

        <form id="ai-form" class="flex flex-col gap-5">
          <!-- Topic -->
          <div class="flex flex-col gap-1.5">
            <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Chủ đề bài viết *</label>
            <input id="ai-topic" type="text" required
              placeholder="VD: Cách quản lý rủi ro khi giao dịch Forex..."
              class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                     placeholder:text-white/20 focus:outline-none focus:border-gold/60" />
          </div>

          <!-- Category + Length -->
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Danh mục</label>
              <div class="relative">
                <select id="ai-category"
                  class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                         focus:outline-none focus:border-gold/60 appearance-none cursor-pointer">
                  <option value="Phân tích thị trường">Phân tích thị trường</option>
                  <option value="Chiến lược giao dịch">Chiến lược giao dịch</option>
                  <option value="Tư duy đầu tư" selected>Tư duy đầu tư</option>
                  <option value="Giáo dục tài chính">Giáo dục tài chính</option>
                  <option value="Tin tức & Cập nhật">Tin tức & Cập nhật</option>
                </select>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gold/60 pointer-events-none text-[10px]">▼</span>
              </div>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Độ dài</label>
              <div class="relative">
                <select id="ai-length"
                  class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                         focus:outline-none focus:border-gold/60 appearance-none cursor-pointer">
                  <option value="short">Ngắn (~400 từ)</option>
                  <option value="medium" selected>Trung bình (~700 từ)</option>
                  <option value="long">Dài (~1400 từ)</option>
                </select>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gold/60 pointer-events-none text-[10px]">▼</span>
              </div>
            </div>
          </div>

          <!-- Generate button -->
          <button id="ai-btn" type="submit"
            class="py-4 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
                   hover:bg-gold-light transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
            Tạo bài viết
          </button>
        </form>

        <!-- AI Result -->
        <div id="ai-preview" class="hidden mt-8 flex flex-col gap-6">
          <hr class="border-white/10" />

          <!-- Header -->
          <div class="flex items-center justify-between">
            <h3 class="font-serif text-lg font-bold">Kết quả AI</h3>
            <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-emerald-400">✓ AI đã tạo xong</span>
          </div>

          <!-- Title + Excerpt -->
          <div class="flex flex-col gap-3">
            <div class="bg-ink-2 border border-white/10 px-4 py-3">
              <p class="font-mono text-[9px] tracking-[0.3em] uppercase text-white/30 mb-1">Tiêu đề</p>
              <p id="ai-prev-title" class="font-serif text-[18px] font-bold text-white leading-snug"></p>
