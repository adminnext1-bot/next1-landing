        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ prompt }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Lỗi không xác định');

      document.getElementById('ai-image-out').src = data.url;
      document.getElementById('ai-image-out').dataset.assetId  = data.assetId || '';
      resultEl.classList.remove('hidden');
      regenBtn.classList.remove('hidden');
      statusEl.textContent = '✓ Xong';
    } catch (err) {
      errEl.textContent = 'Lỗi: ' + err.message;
      errEl.classList.remove('hidden');
      statusEl.textContent = '';
    } finally {
      btn.disabled = false;
    }
  }

  document.getElementById('ai-image-generate').addEventListener('click', generateAiImage);
  document.getElementById('ai-image-regen').addEventListener('click', generateAiImage);

  document.getElementById('ai-image-use').addEventListener('click', () => {
    const imgEl   = document.getElementById('ai-image-out');
    const assetId = imgEl.dataset.assetId;
    const url     = imgEl.src;

    // Set as cover image in form
    document.getElementById('image-preview').src = url;
    document.getElementById('image-preview').classList.remove('hidden');
    document.getElementById('image-placeholder').classList.add('hidden');
    document.getElementById('image-clear').classList.remove('hidden');
    document.getElementById('f-image-ref').value = assetId;
    pendingImageFile = null; // Already uploaded server-side

    document.getElementById('ai-image-panel').classList.add('hidden');
    document.getElementById('ai-image-status').textContent = '';
    document.getElementById('ai-image-result').classList.add('hidden');
    document.getElementById('ai-image-regen').classList.add('hidden');
  });

  // ── BROKER MANAGEMENT ──
  document.getElementById('b-name').addEventListener('input', e => {
    if (document.getElementById('broker-edit-id').value) return;
    document.getElementById('b-slug').value = slugify(e.target.value);
  });

  // Logo upload for broker
  let brokerPendingLogo = null;
  document.getElementById('b-logo-file').addEventListener('change', e => {
    const file = e.target.files?.[0];
    if (!file) return;
    brokerPendingLogo = file;
    const reader = new FileReader();
    reader.onload = ev => {
      document.getElementById('b-logo-preview').src = ev.target.result;
      document.getElementById('b-logo-preview').classList.remove('hidden');
      document.getElementById('b-logo-placeholder').classList.add('hidden');
    };
    reader.readAsDataURL(file);
    document.getElementById('b-logo-ref').value = '';
  });

  async function uploadBrokerLogo() {
    if (document.getElementById('b-logo-ref').value) return document.getElementById('b-logo-ref').value;
    if (!brokerPendingLogo) return null;
    const statusEl = document.getElementById('b-logo-status');
    statusEl.classList.remove('hidden'); statusEl.textContent = 'Đang tải logo...';
    try {
      const res = await fetch(ASSETS, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${TOKEN}`, 'Content-Type': brokerPendingLogo.type },
        body: brokerPendingLogo,
      });
      if (!res.ok) throw new Error(await res.text());
      const data = await res.json();
      const assetId = data.document._id;
      statusEl.textContent = '✓ Logo đã tải lên';
      document.getElementById('b-logo-ref').value = assetId;
      return assetId;
    } catch (err) {
      statusEl.textContent = '✗ Lỗi: ' + err.message;
      throw err;
    }
  }

  document.getElementById('broker-form').addEventListener('submit', async e => {
    e.preventDefault();
    const btn     = document.getElementById('broker-submit-btn');
    const success = document.getElementById('broker-success');
    const errEl   = document.getElementById('broker-error');
    btn.disabled = true; btn.textContent = 'Đang lưu...';
    success.classList.add('hidden'); errEl.classList.add('hidden');

    try {
      const logoAssetId = await uploadBrokerLogo();
      const editId   = document.getElementById('broker-edit-id').value;
      const name     = document.getElementById('b-name').value.trim();
      const slug     = slugify(document.getElementById('b-slug').value.trim() || name);
      const tagline  = document.getElementById('b-tagline').value.trim();
      const affiliate= document.getElementById('b-affiliate').value.trim();
      const ratingVal= parseFloat(document.getElementById('b-rating').value) || null;
      const cashback = document.getElementById('b-cashback').value.trim();
      const deposit  = document.getElementById('b-deposit').value.trim();
      const spread   = document.getElementById('b-spread').value.trim();
      const leverage = document.getElementById('b-leverage').value.trim();
      const reg      = document.getElementById('b-regulation').value.trim();
      const prosRaw  = document.getElementById('b-pros').value.trim();
      const consRaw  = document.getElementById('b-cons').value.trim();
      const featured = document.getElementById('b-featured').checked;

      const doc = {
        name, tagline, affiliateLink: affiliate || undefined,
        slug: { _type: 'slug', current: slug },
        rating: ratingVal,
        cashbackRate: cashback || undefined,
        minDeposit: deposit || undefined,
        spread: spread || undefined,
        leverage: leverage || undefined,
        regulation: reg || undefined,
        pros: prosRaw ? prosRaw.split('\n').map(s=>s.trim()).filter(Boolean) : [],
        cons: consRaw ? consRaw.split('\n').map(s=>s.trim()).filter(Boolean) : [],
        featured,
      };
      if (logoAssetId) doc.logo = { _type: 'image', asset: { _type: 'reference', _ref: logoAssetId } };

      let mutations;
      if (editId) {
        mutations = [{ patch: { id: editId, set: doc } }];
      } else {
        mutations = [{ create: { _type: 'broker', ...doc } }];
      }
      const res = await fetch(`${API}/mutate/${DATASET}`, {
        method: 'POST', headers: HEADERS,
        body: JSON.stringify({ mutations }),
      });
      if (!res.ok) throw new Error(await res.text());
      if (DEPLOY_HOOK) fetch(DEPLOY_HOOK, { method: 'POST' }).catch(() => {});
      success.classList.remove('hidden');
      resetBrokerForm();
    } catch (err) {
      errEl.textContent = 'Lỗi: ' + (err?.message ?? 'Thử lại.');
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false; btn.textContent = 'Lưu sàn đối tác';
    }
  });

  function resetBrokerForm() {
    document.getElementById('broker-form').reset();
    document.getElementById('broker-edit-id').value = '';
    document.getElementById('broker-form-heading').textContent = 'Thêm sàn mới';
    document.getElementById('broker-cancel').classList.add('hidden');
    document.getElementById('b-logo-preview').classList.add('hidden');
    document.getElementById('b-logo-placeholder').classList.remove('hidden');
    document.getElementById('b-logo-ref').value = '';
    brokerPendingLogo = null;
  }

  document.getElementById('broker-cancel').addEventListener('click', resetBrokerForm);

  async function loadBrokers() {
    const listEl = document.getElementById('broker-list');
    listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Đang tải...</p>';
    try {
      const q = encodeURIComponent('*[_type == "broker"] | order(featured desc, order asc, name asc) { _id, name, slug, rating, cashbackRate, featured, affiliateLink }');
      const res = await fetch(`${API}/query/${DATASET}?query=${q}`, { headers: HEADERS });
      const { result } = await res.json();
      const brokers = result ?? [];

      if (!brokers.length) {
        listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Chưa có sàn nào.</p>';
        return;
      }

      listEl.innerHTML = brokers.map(b => `
        <div class="flex items-center justify-between border border-white/10 px-4 py-4 hover:border-white/20 transition-colors ${b.featured ? 'border-l-2 border-l-gold/50' : ''}">
          <div class="flex-1 min-w-0 mr-4">
            <div class="flex items-center gap-2">
              ${b.featured ? '<span class="font-mono text-[9px] tracking-widest uppercase bg-gold/15 text-gold px-2 py-0.5">Nổi bật</span>' : ''}
              <p class="text-[14px] text-white/90 font-medium">${b.name}</p>
            </div>
            <p class="font-mono text-[11px] text-white/30 mt-0.5">
              ${b.cashbackRate ? `Cashback: ${b.cashbackRate} · ` : ''}${b.rating ? `★ ${b.rating}/5` : ''}
            </p>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <button data-id="${b._id}" class="broker-edit-btn font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-gold transition-colors">Sửa</button>
            <a href="/brokers/${b.slug?.current}" target="_blank"
               class="font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-gold no-underline transition-colors">Xem</a>
            <button data-id="${b._id}" class="broker-delete-btn font-mono text-[10px] tracking-[0.15em] uppercase text-white/40 hover:text-red-400 transition-colors">Xóa</button>
          </div>
        </div>
      `).join('');

      document.querySelectorAll('.broker-edit-btn').forEach(btn => {
        btn.addEventListener('click', () => loadBrokerForEdit(btn.dataset.id));
      });
      document.querySelectorAll('.broker-delete-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm(`Xóa sàn này?`)) return;
          await fetch(`${API}/mutate/${DATASET}`, {
            method: 'POST', headers: HEADERS,
            body: JSON.stringify({ mutations: [{ delete: { id: btn.dataset.id } }] }),
          });
          if (DEPLOY_HOOK) fetch(DEPLOY_HOOK, { method: 'POST' }).catch(() => {});
          loadBrokers();
        });
      });
    } catch {
      listEl.innerHTML = '<p class="text-red-400 text-[13px] font-mono">Không tải được danh sách.</p>';
    }
  }

  async function loadBrokerForEdit(id) {
    const q = encodeURIComponent(`*[_id == "${id}"][0]{ ..., "logoUrl": logo.asset->url }`);
    const res = await fetch(`${API}/query/${DATASET}?query=${q}`, { headers: HEADERS });
    const { result: b } = await res.json();
    if (!b) return;

    document.getElementById('broker-edit-id').value = b._id;
    document.getElementById('b-name').value      = b.name ?? '';
    document.getElementById('b-slug').value      = b.slug?.current ?? '';
    document.getElementById('b-tagline').value   = b.tagline ?? '';
    document.getElementById('b-affiliate').value = b.affiliateLink ?? '';
    document.getElementById('b-rating').value    = b.rating ?? '';
    document.getElementById('b-cashback').value  = b.cashbackRate ?? '';
    document.getElementById('b-deposit').value   = b.minDeposit ?? '';
    document.getElementById('b-spread').value    = b.spread ?? '';
    document.getElementById('b-leverage').value  = b.leverage ?? '';
    document.getElementById('b-regulation').value= b.regulation ?? '';
    document.getElementById('b-pros').value      = (b.pros ?? []).join('\n');
    document.getElementById('b-cons').value      = (b.cons ?? []).join('\n');
    document.getElementById('b-featured').checked= b.featured ?? false;

    if (b.logo?.asset?._ref) document.getElementById('b-logo-ref').value = b.logo.asset._ref;
    if (b.logoUrl) {
      document.getElementById('b-logo-preview').src = b.logoUrl;
      document.getElementById('b-logo-preview').classList.remove('hidden');
      document.getElementById('b-logo-placeholder').classList.add('hidden');
    }

    document.getElementById('broker-form-heading').textContent = `Chỉnh sửa: ${b.name}`;
    document.getElementById('broker-cancel').classList.remove('hidden');

    // Switch to broker-form tab
    TABS.forEach(t => document.getElementById(`tab-${t}`)?.classList.toggle('hidden', t !== 'broker-form'));
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active-tab'));
    document.querySelectorAll('[data-tab="broker-form"]').forEach(btn => btn.classList.add('active-tab'));
    window.scrollTo(0, 0);
  }
</script>

</body>
</html>
