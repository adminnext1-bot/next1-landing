---
import '../styles/global.css';

const PROJECT_ID = import.meta.env.SANITY_PROJECT_ID;
const DATASET    = import.meta.env.SANITY_DATASET ?? 'production';
const TOKEN      = import.meta.env.SANITY_TOKEN;
---

<!doctype html>
<html lang="vi" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NEXT 1 — Quản lý Blog</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet" />
</head>
<body class="bg-ink text-white min-h-screen">

  <!-- Password gate -->
  <div id="gate" class="fixed inset-0 bg-ink z-50 flex items-center justify-center px-6">
    <div class="w-full max-w-sm">
      <p class="font-mono text-[10px] tracking-[0.4em] uppercase text-gold mb-6 text-center">// NEXT 1 Admin</p>
      <h1 class="font-serif text-3xl font-bold text-center mb-8">Đăng nhập</h1>
      <input
        id="password-input"
        type="password"
        placeholder="Nhập mật khẩu..."
        class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
               placeholder:text-white/20 focus:outline-none focus:border-gold/60 mb-3"
      />
      <button
        id="password-btn"
        class="w-full py-3 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
               hover:bg-gold-light transition-all duration-300"
      >
        Vào trang quản lý
      </button>
      <p id="gate-error" class="hidden mt-3 text-center text-red-400 text-[13px]">Sai mật khẩu.</p>
    </div>
  </div>

  <!-- Admin panel -->
  <div id="panel" class="hidden max-w-3xl mx-auto px-6 py-12">

    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
      <div>
        <p class="font-mono text-[10px] tracking-[0.4em] uppercase text-gold mb-1">// NEXT 1 Admin</p>
        <h1 class="font-serif text-3xl font-bold">Viết bài mới</h1>
      </div>
      <a href="/blog" class="font-mono text-[11px] tracking-[0.2em] uppercase text-white/40 hover:text-gold no-underline transition-colors">
        ← Blog
      </a>
    </div>

    <!-- Form -->
    <form id="post-form" class="flex flex-col gap-5">

      <!-- Title -->
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tiêu đề *</label>
        <input
          id="f-title" type="text" required
          placeholder="Tiêu đề bài viết..."
          class="bg-ink-2 border border-white/10 px-4 py-3 text-[15px] text-white/90
                 placeholder:text-white/20 focus:outline-none focus:border-gold/60"
        />
      </div>

      <!-- Slug -->
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Đường dẫn (tự động tạo)</label>
        <input
          id="f-slug" type="text"
          placeholder="duong-dan-bai-viet"
          class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/60
                 placeholder:text-white/20 focus:outline-none focus:border-gold/60 font-mono"
        />
      </div>

      <!-- Excerpt -->
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tóm tắt</label>
        <textarea
          id="f-excerpt" rows="2"
          placeholder="Mô tả ngắn hiện trên trang danh sách..."
          class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                 placeholder:text-white/20 focus:outline-none focus:border-gold/60 resize-none"
        ></textarea>
      </div>

      <!-- Category + Author -->
      <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-1.5">
          <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Danh mục</label>
          <div class="relative">
            <select
              id="f-category"
              class="w-full bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                     focus:outline-none focus:border-gold/60 appearance-none cursor-pointer"
            >
              <option value="">— Chọn danh mục —</option>
              <option value="Phân tích thị trường">Phân tích thị trường</option>
              <option value="Chiến lược giao dịch">Chiến lược giao dịch</option>
              <option value="Tư duy đầu tư">Tư duy đầu tư</option>
              <option value="Giáo dục tài chính">Giáo dục tài chính</option>
              <option value="Tin tức & Cập nhật">Tin tức & Cập nhật</option>
            </select>
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-gold/60 pointer-events-none text-[10px]">▼</span>
          </div>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Tác giả</label>
          <input
            id="f-author" type="text"
            value="NEXT 1 Team"
            class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                   focus:outline-none focus:border-gold/60"
          />
        </div>
      </div>

      <!-- Body -->
      <div class="flex flex-col gap-1.5">
        <label class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/40">Nội dung bài viết *</label>
        <textarea
          id="f-body" rows="16" required
          placeholder="Viết nội dung bài viết ở đây...

Bạn có thể xuống dòng để tạo đoạn văn mới."
          class="bg-ink-2 border border-white/10 px-4 py-3 text-[14px] text-white/90
                 placeholder:text-white/20 focus:outline-none focus:border-gold/60 resize-y font-sans leading-relaxed"
        ></textarea>
      </div>

      <!-- Submit -->
      <button
        id="submit-btn" type="submit"
        class="mt-2 py-4 bg-gold text-ink text-[12px] font-semibold tracking-[0.15em] uppercase
               hover:bg-gold-light transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Đăng bài
      </button>

      <p id="form-success" class="hidden text-center text-emerald-400 text-[14px] py-2">
        ✓ Đăng bài thành công!
      </p>
      <p id="form-error" class="hidden text-center text-red-400 text-[14px] py-2">
        Có lỗi xảy ra. Vui lòng thử lại.
      </p>

    </form>

    <!-- Post list -->
    <div class="mt-16">
      <h2 class="font-serif text-xl font-bold mb-6">Bài viết đã đăng</h2>
      <div id="post-list" class="flex flex-col gap-3">
        <p class="text-white/30 text-[13px] font-mono">Đang tải...</p>
      </div>
    </div>

  </div>

  <script define:vars={{ PROJECT_ID, DATASET, TOKEN }}>
    const ADMIN_PASSWORD = 'next1admin2026';
    const API = `https://${PROJECT_ID}.api.sanity.io/v2024-01-01/data`;

    // --- Gate ---
    const gate     = document.getElementById('gate');
    const panel    = document.getElementById('panel');
    const pwdInput = document.getElementById('password-input');
    const pwdBtn   = document.getElementById('password-btn');
    const gateErr  = document.getElementById('gate-error');

    function unlock() {
      if (pwdInput.value === ADMIN_PASSWORD) {
        gate.style.display = 'none';
        panel.classList.remove('hidden');
        loadPosts();
      } else {
        gateErr.classList.remove('hidden');
        pwdInput.value = '';
      }
    }

    pwdBtn.addEventListener('click', unlock);
    pwdInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') unlock(); });

    // --- Slug generator ---
    document.getElementById('f-title').addEventListener('input', (e) => {
      const slug = e.target.value
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim().replace(/\s+/g, '-');
      document.getElementById('f-slug').value = slug;
    });

    // --- Submit ---
    document.getElementById('post-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn     = document.getElementById('submit-btn');
      const success = document.getElementById('form-success');
      const errEl   = document.getElementById('form-error');

      btn.disabled    = true;
      btn.textContent = 'Đang đăng...';
      success.classList.add('hidden');
      errEl.classList.add('hidden');

      const title    = document.getElementById('f-title').value.trim();
      const slug     = document.getElementById('f-slug').value.trim() || title.toLowerCase().replace(/\s+/g, '-');
      const excerpt  = document.getElementById('f-excerpt').value.trim();
      const category = document.getElementById('f-category').value;
      const author   = document.getElementById('f-author').value.trim();
      const bodyText = document.getElementById('f-body').value.trim();

      // Convert plain text to Sanity block content
      const body = bodyText.split('\n\n').filter(p => p.trim()).map(para => ({
        _type: 'block',
        _key: Math.random().toString(36).slice(2),
        style: 'normal',
        markDefs: [],
        children: [{ _type: 'span', _key: Math.random().toString(36).slice(2), text: para.trim(), marks: [] }],
      }));

      const doc = {
        _type: 'post',
        title,
        slug: { _type: 'slug', current: slug },
        excerpt,
        category,
        author,
        publishedAt: new Date().toISOString(),
        body,
      };

      try {
        const res = await fetch(`${API}/mutate/${DATASET}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${TOKEN}`,
          },
          body: JSON.stringify({ mutations: [{ create: doc }] }),
        });

        if (!res.ok) throw new Error(await res.text());

        success.classList.remove('hidden');
        document.getElementById('post-form').reset();
        document.getElementById('f-author').value = 'NEXT 1 Team';
        loadPosts();
      } catch (err) {
        console.error(err);
        errEl.classList.remove('hidden');
      } finally {
        btn.disabled    = false;
        btn.textContent = 'Đăng bài';
      }
    });

    // --- Load posts ---
    async function loadPosts() {
      const listEl = document.getElementById('post-list');
      try {
        const query = encodeURIComponent('*[_type == "post"] | order(publishedAt desc) { _id, title, slug, publishedAt, category }');
        const res   = await fetch(`${API}/query/${DATASET}?query=${query}`, {
          headers: { 'Authorization': `Bearer ${TOKEN}` },
        });
        const { result } = await res.json();

        if (!result || result.length === 0) {
          listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Chưa có bài viết nào.</p>';
          return;
        }

        listEl.innerHTML = result.map(p => `
          <div class="flex items-center justify-between border border-white/10 px-4 py-3 hover:border-white/20 transition-colors">
            <div>
              <p class="text-[14px] text-white/90">${p.title}</p>
              <p class="text-[11px] font-mono text-white/30 mt-0.5">
                ${p.category ?? '—'} · ${p.publishedAt ? new Date(p.publishedAt).toLocaleDateString('vi-VN') : 'Chưa đặt ngày'}
              </p>
            </div>
            <a href="/blog/${p.slug?.current}" target="_blank"
               class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold hover:text-gold-light no-underline transition-colors">
              Xem →
            </a>
          </div>
        `).join('');
      } catch {
        listEl.innerHTML = '<p class="text-red-400 text-[13px] font-mono">Không tải được danh sách bài.</p>';
      }
    }
  </script>

</body>
</html>
