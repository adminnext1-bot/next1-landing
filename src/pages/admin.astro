    if (!filtered.length) {
      listEl.innerHTML = '<p class="text-white/30 text-[13px] font-mono">Không có bài viết nào phù hợp.</p>';
      return;
    }

    listEl.innerHTML = filtered.map(p => `
      <div class="flex items-center justify-between border border-white/10 px-4 py-4 hover:border-white/20 transition-colors">
        <div class="flex-1 min-w-0 mr-4">
          <p class="text-[14px] text-white/90 truncate">${p.title ?? ''}</p>
          <div class="flex items-center gap-2 mt-0.5 flex-wrap">
            ${p.category ? `<span class="font-mono text-[10px] tracking-[0.2em] uppercase text-gold">${p.category}</span>` : ''}
            ${p.category && p.author ? '<span class="text-white/20 text-[10px]">·</span>' : ''}
            ${p.author ? `<span class="font-mono text-[10px] text-white/30">${p.author}</span>` : ''}
            ${(p.category || p.author) && p.publishedAt ? '<span class="text-white/20 text-[10px]">·</span>' : ''}
