---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/common/Nav.astro';
import Footer from '../../components/common/Footer.astro';
import { getAllPosts } from '../../lib/sanity';
import '../../styles/global.css';

const posts = await getAllPosts();

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('vi-VN', {
    day: '2-digit', month: '2-digit', year: 'numeric',
  });
}
---

<Layout
  title="Blog – NEXT 1"
  description="Góc nhìn chuyên sâu về đầu tư, giao dịch và tư duy tài chính từ đội ngũ NEXT 1."
>
  <Nav />
  <main class="pt-[72px] min-h-screen">

    <!-- Hero -->
    <section class="relative border-b border-white/10 px-6 md:px-16 py-20 md:py-28 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_0%,rgba(201,168,76,0.07),transparent_70%)] pointer-events-none"></div>
      <div class="relative z-10 max-w-6xl mx-auto">
        <span class="section-label mb-4">// Kiến thức & Góc nhìn</span>
        <h1 class="section-title max-w-2xl">
          Insight từ<br />
          <span class="text-gold italic font-normal">NEXT 1.</span>
        </h1>
        <p class="mt-6 text-[16px] text-white/60 font-light max-w-md leading-relaxed">
          Phân tích thị trường, tư duy đầu tư, và những bài học thực chiến từ đội ngũ giao dịch chuyên nghiệp.
        </p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="px-6 md:px-16 py-16 md:py-24">
      <div class="max-w-6xl mx-auto">

        {posts.length === 0 ? (
          <div class="text-center py-24 text-white/30 font-mono text-sm tracking-widest uppercase">
            Chưa có bài viết nào.
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post, i) => (
              <article
                class="reveal group border border-white/10 hover:border-gold/40 transition-colors duration-300 flex flex-col"
                style={`animation-delay: ${i * 0.08}s`}
              >
                <!-- Cover image -->
                {post.coverImage?.asset?.url ? (
                  <div class="overflow-hidden aspect-[16/9]">
                    <img
                      src={post.coverImage.asset.url}
                      alt={post.coverImage.alt ?? post.title}
                      class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 scale-100 group-hover:scale-105"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/9] bg-ink-2 border-b border-white/10 flex items-center justify-center">
                    <span class="font-serif text-4xl text-gold/20 italic">N1</span>
                  </div>
                )}

                <!-- Content -->
                <div class="flex flex-col flex-1 p-6">
                  <!-- Meta -->
                  <div class="flex items-center gap-3 mb-4">
                    {post.category && (
                      <span class="font-mono text-[10px] tracking-[0.3em] uppercase text-gold">
                        {post.category}
                      </span>
                    )}
                    {post.category && post.publishedAt && (
                      <span class="text-white/20 text-[10px]">·</span>
                    )}
                    {post.publishedAt && (
                      <span class="font-mono text-[10px] tracking-[0.15em] text-white/30">
                        {formatDate(post.publishedAt)}
                      </span>
                    )}
                  </div>

                  <!-- Title -->
                  <h2 class="font-serif text-[20px] leading-tight font-bold group-hover:text-gold transition-colors duration-200 mb-3">
                    {post.title}
                  </h2>

                  <!-- Excerpt -->
                  {post.excerpt && (
                    <p class="text-[14px] text-white/50 font-light leading-relaxed flex-1 mb-6">
                      {post.excerpt}
                    </p>
                  )}

                  <!-- Read more -->
                  <a
                    href={`/blog/${post.slug.current}`}
                    class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.2em] uppercase text-gold
                           no-underline hover:gap-3 transition-all duration-200"
                  >
                    Đọc tiếp <span>→</span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}

      </div>
    </section>

    <Footer />
  </main>
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
