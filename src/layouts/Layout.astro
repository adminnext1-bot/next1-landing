---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'NEXT 1 – Hiểu Biết. Đầu Tư. Thịnh Vượng.',
  description = 'Hệ sinh thái đầu tư & trading dành cho thế hệ nhà đầu tư Việt Nam mới — kỷ luật, có hệ thống, không cảm xúc.',
} = Astro.props;
---

<!doctype html>
<html lang="vi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-reveal via IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      // Sticky nav shadow on scroll
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('shadow-[0_4px_40px_rgba(0,0,0,0.6)]', window.scrollY > 20);
      });

      // Mobile menu
      const toggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const barTop = document.getElementById('bar-top');
      const barMid = document.getElementById('bar-mid');
      const barBot = document.getElementById('bar-bot');

      function openMenu() {
        mobileMenu?.classList.add('is-open');
        toggle?.setAttribute('aria-expanded', 'true');
        barTop?.classList.add('rotate-45', 'translate-y-[6px]', '!bg-gold');
        barMid?.classList.add('opacity-0');
        barBot?.classList.add('-rotate-45', '-translate-y-[6px]', '!bg-gold');
      }

      function closeMenu() {
        mobileMenu?.classList.remove('is-open');
        toggle?.setAttribute('aria-expanded', 'false');
        barTop?.classList.remove('rotate-45', 'translate-y-[6px]', '!bg-gold');
        barMid?.classList.remove('opacity-0');
        barBot?.classList.remove('-rotate-45', '-translate-y-[6px]', '!bg-gold');
      }

      toggle?.addEventListener('click', () => {
        mobileMenu?.classList.contains('is-open') ? closeMenu() : openMenu();
      });

      mobileMenu?.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', closeMenu);
      });
    </script>
  </body>
</html>
